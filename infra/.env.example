# Копировать в .env и менять значения!

# PostgreSQL (обязательно)
POSTGRES_USER=postgres              # стандартный пользователь (можно не менять)
POSTGRES_PASSWORD=secure_vkr_2026   # сильный пароль, меняй на свой
POSTGRES_DB=vkr_main

# JWT (обязательно для Auth)
JWT_SECRET=change_this_to_a_very_long_random_string_64_chars_min_2026
JWT_ALGORITHM=HS256                 # проще для начала, RS256 требует ключей

# Email (позже, пока можно закомментировать)
# EMAIL_ENABLED=true
# EMAIL_AUTO_DETECT=true
# EMAIL_HOST=
# EMAIL_PORT=465
# EMAIL_USER=your@yandex.ru
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=your@yandex.ru
# EMAIL_USE_SSL=true
# EMAIL_USE_STARTTLS=false
# LOGIN_CODE_EMAIL_SUBJECT=Your VKR login code
# SHOW_LOGIN_CODE=true
# LOG_LOGIN_CODE=true
